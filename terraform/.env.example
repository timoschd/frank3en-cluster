# GA credentials for backend
export GOOGLE_APPLICATION_CREDENTIALS="/path/to/your/gcp-key.json"

# Tailscale API Credentials
export TAILSCALE_OAUTH_CLIENT_ID="your_client_id"
export TAILSCALE_OAUTH_CLIENT_SECRET="your_client_secret"

# K3s Security
export TF_VAR_k3s_token="a_very_long_random_string_12345"
export TF_VAR_tailnet_name="your-tailnet.ts.net"

# Phase switch: false for bootstrap on LAN, true for travel mode via Tailscale
export TF_VAR_use_tailscale="true"

# SSH login for phase 1
export TF_VAR_default_ssh_key_path="$HOME/.ssh/id_..."
export TF_VAR_default_ssh_password=""

# Set after phase 1: Tailscale IP of pi-brain (master)
export TF_VAR_master_tailscale_ip="100.x.y.z"
